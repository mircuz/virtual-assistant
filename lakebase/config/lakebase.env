# ==============================================================================
# Virtual Assistant — Environment Configuration
# ==============================================================================

# --- Databricks ---
# Workspace URL. Auto-detected in notebooks; required when running standalone API.
DATABRICKS_HOST=https://adb-2338896885246877.17.azuredatabricks.net/
# API token. Auto-detected from notebook context; fill in for standalone API use.
DATABRICKS_TOKEN=

# --- Model Serving Endpoints ---
# Foundation Model API — pay-per-token, no deployment needed.
# For real-time phone calls: 8B is ~5x faster than 70B with acceptable quality.
# Upgrade to databricks-meta-llama-3-3-70b-instruct for higher quality if latency allows.
DATABRICKS_ENDPOINT=databricks-meta-llama-3-3-70b-instruct
DATABRICKS_TTS_ENDPOINT=kokoro-tts-endpoint

# --- Lakebase Autoscaling (PostgreSQL) ---
# Project: demo-assistant-autoscale (westus Azure)
LAKEBASE_PROJECT_ID=12ce9334-6393-4636-823f-3672b36702c9
LAKEBASE_BRANCH=br-fancy-fire-e3ase6k2
# Full endpoint resource path used for OAuth credential generation.
LAKEBASE_ENDPOINT=projects/12ce9334-6393-4636-823f-3672b36702c9/branches/br-fancy-fire-e3ase6k2/endpoints/primary
# Host from the Data API / connection string
LAKEBASE_HOST=ep-morning-salad-e3uf0lci.database.westus.azuredatabricks.net
LAKEBASE_PORT=5432
# Autoscaling default database (NOT "postgres" — that schema is restricted)
LAKEBASE_DB=databricks_postgres
# Auth mode A — native Postgres role (RECOMMENDED, never expires):
#   Run cell 2b once with a temporary token → it prints LAKEBASE_USER + LAKEBASE_PASSWORD.
#   Copy those values here; the native password never rotates.
# Auth mode B — OAuth (temporary, 1-hour token from local CLI):
#   databricks postgres generate-database-credential \
#     projects/12ce9334-6393-4636-823f-3672b36702c9/branches/br-fancy-fire-e3ase6k2/endpoints/primary \
#     -o json | jq -r '.token'
#   Then set LAKEBASE_USER=mirco.meazzo@databricks.com and LAKEBASE_PASSWORD=<token>
LAKEBASE_USER=authenticator
LAKEBASE_PASSWORD=dGn1t2LGlbBKUqX8sZ5mDE9px2IrLgDu
LAKEBASE_SSLMODE=require
LAKEBASE_SCHEMA=assistant_mochi

# --- Voice (optional) ---
TTS_VOICE=af_sky
STT_MODEL=base

# --- Paths ---
VOLUME_BASE=/Volumes/mircom_test/assistant_mochi/data
